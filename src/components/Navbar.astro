---
const { user } = Astro.locals;
const pathname = Astro.url.pathname;

const receiptsActive = pathname.startsWith("/receipts") && !pathname.startsWith("/receipts/upload");
const uploadActive = pathname.startsWith("/receipts/upload");
---

<nav class="border-border bg-background sticky top-0 z-10 border-b">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a
      href={user ? "/dashboard" : "/"}
      class="text-foreground hover:text-foreground/80 text-lg font-semibold transition-colors"
    >
      ClearSpend
    </a>

    {
      user ? (
        <div class="flex items-center gap-5">
          <a
            href="/receipts"
            class:list={`text-sm transition-colors ${
              receiptsActive ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Receipts
          </a>
          <a
            href="/receipts/upload"
            class:list={`text-sm transition-colors ${
              uploadActive ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Upload
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
              Sign out
            </button>
          </form>
        </div>
      ) : (
        <div class="flex items-center gap-4">
          <a
            href="/auth/signin"
            class:list={`text-sm transition-colors ${
              pathname === "/auth/signin"
                ? "text-foreground font-medium"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Sign in
          </a>
          <a
            href="/auth/signup"
            class="rounded-lg bg-purple-600 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-purple-500"
          >
            Sign up
          </a>
        </div>
      )
    }
  </div>
</nav>
