---
const { user } = Astro.locals;
const pathname = Astro.url.pathname;

const receiptsActive =
  pathname.startsWith("/receipts") && !pathname.startsWith("/receipts/upload");
const uploadActive = pathname.startsWith("/receipts/upload");
---

<nav class="sticky top-0 z-10 border-b border-border bg-background">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a
      href={user ? "/dashboard" : "/"}
      class="text-lg font-semibold text-foreground transition-colors hover:text-foreground/80"
    >
      ClearSpend
    </a>

    {
      user ? (
        <div class="flex items-center gap-5">
          <a
            href="/receipts"
            class={`text-sm transition-colors ${
              receiptsActive
                ? "font-medium text-foreground"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Receipts
          </a>
          <a
            href="/receipts/upload"
            class={`text-sm transition-colors ${
              uploadActive
                ? "font-medium text-foreground"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Upload
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Sign out
            </button>
          </form>
        </div>
      ) : (
        <div class="flex items-center gap-4">
          <a
            href="/auth/signin"
            class={`text-sm transition-colors ${
              pathname === "/auth/signin"
                ? "font-medium text-foreground"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            Sign in
          </a>
          <a
            href="/auth/signup"
            class="rounded-lg bg-purple-600 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-purple-500"
          >
            Sign up
          </a>
        </div>
      )
    }
  </div>
</nav>
